# --- LLM ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic            # anthropic | openai | local
LLM_MODEL=claude-opus-4-7

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/library_agent

# --- Crawler ---
NCCU_SYLLABUS_BASE_URL=https://qrysub.nccu.edu.tw
CRAWLER_POLITENESS_DELAY_MS=1500
CRAWLER_USER_AGENT=NCCU-Library-Agent/0.1 (+mailto:clhung@nccu.edu.tw)

# --- External bibliographic APIs ---
GOOGLE_BOOKS_API_KEY=
NLA_OPEN_DATA_BASE_URL=https://openapi.ncl.edu.tw

# --- Ex Libris Alma ---
ALMA_API_BASE_URL=https://api-ap.hosted.exlibrisgroup.com/almaws/v1
ALMA_API_KEY=
ALMA_Z3950_HOST=
ALMA_Z3950_PORT=210
ALMA_Z3950_DB=

# --- Runtime ---
LOG_LEVEL=INFO
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.6
